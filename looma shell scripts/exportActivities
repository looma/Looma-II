#   filename:  exportActivities
#   create a CSV of all activities:
#  filter to exclude ft's "quiz", "text" and "chapter"

#    NOTE: FTP this from looma.website to laptop, open in Numbers [to preserve Nepali font], export to .xlsx, open in Excel


mongoexport --db=looma  --collection=activities --type=csv --out=activities.csv \
--fields="dn,ndn,ch_id,cl_lo,cl_hi,key1,key2,key3,key4,lang,src,ft,fn,nfn,fp" \
--query='{"ft":{"$nin":["quiz","text","chapter"]}}'
