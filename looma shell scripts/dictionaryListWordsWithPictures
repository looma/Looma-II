# generate file "dictionary_words" with all the words
#               "dictionary_words_with_pictures" with all the words that have pictures
#               "dictionary_words_without_pictures" with all the words that dont have pictures

DIR="/Users/skip/Desktop/dictionary/"

#Generate list of pictures for words

ls "/usr/local/var/www/content/dictionary images" | grep -v thumb | sed 's/\.jpg//' > $DIR/dictionary_words_with_pictures
sort $DIR/dictionary_words_with_pictures > $DIR/dictionary_words_with_pictures

#generate list of all dictionary words [or nouns]

mongoexport --db=looma --collection=dictionary --type=csv  --fields="en" --query='{"meanings.part":"noun"}'  --out=$DIR/dictionary_words

# this sort takes too long offline - use an online sort like https://www.textfixer.com/tools/sort-lines-alphabetically-online.php
sort -o $DIR/dictionary_words > $DIR/dictionary_words

#Generate list of words without pictures

comm -23  $DIR/dictionary_words \
          $DIR/dictionary_words_with_pictures > \
          $DIR/dictionary_words_without_pictures

#show the list of files
l '$DIR/dictionary_*'
