#!/bin/bash
#
#  filename: loomaupdater
#       VERSION 7.0
#       author: skip
#       date:   SEP 2021, OCT 2023, FEB 2024, MAY 2024, OCT 2025, MAY 2026
#
#     revised OCT 2025 to add option to sync with "preview" version of Looma
#     revised OCT 2023 to check 'archivetimestamp.txt' to see if an update is needed
#       on both /Looma and /content
#     revised MAY 2026 bug fixes for "preview" and general cleanup
#
#  used to update a pre-installed Looma by installing latest code, database & content
#           only changed or brand new files are transferred
#
#   source files to be updated may be
#    - on a USB stick at /media/odroid/LOOMA/loomaupdate (the "U" option)
#    - or, on the Internet at rsync.net (the "I" option)
#
#   file structure expected if on the USB:
#
#       Looma/*               (full set of new Looma code)
#       Looma/mongo-dump/dump/looma/   (latest mongodump of the new database content)
#       content/*   (folders with new content)
#                   (these are usually NEW folders,
#                      but this can be used to overwrite existing content folders)
#    optionally other content folders by uncommenting code below, like
#       maps2018/*
#       ePaath/*
#    or other content folders
#
#   steps performed:
#.      set proper directory to download to
#       sync newer code files into existing Looma code
#       use mongorestore to load new data into the existing mongo database
#                  (merging into some collections, like 'lessons' and 'text-files')
#       sync newer content files into "content" directory
#
#       CALL with "loomaupdate [dryrun] [preview]
#           optional arg "dryrun" for testing the script without actually changng files
#           optional arg "preview" for sync'ing with the PREVIEW version instead of RELEASE version of Looma

#RSYNC options used:

# -rtvz     recursive, set modification time, verbose, use compression
# --progress, --update, --delete, --no-perms
# --chmod=ugo=rwX
# --chown=looma:looma. NOT USED - files get 58198:58198 on Update Server, then get odroid:odroid on Looma's that download from the update server
# optional: --dry-run
# --include ".ssh/"  --exclude ".[!.]*" --exclude "vendor/" --exclude "composer*"
# --size-only for files in content/

checksudo() {
    if [ "$(id -u)" -ne 0 ]; then
        echo "This script must be run as root. Please run again using 'sudo loomaupdate'"
        exit 1
    fi
}   #  end checksudo()

# display result of previous  command
result () {
    if [[ $1 -ne 0 ]]
    then
        echo "****************************************************************"
        echo "ERROR: previous operation returned $1"
    else
        echo "****************************************************************"
        echo "operation successful"
    fi
}  #  end result()

pause () {
   echo " Paused $1"
   read -p "     press [Enter] to continue"
}  #  end pause()

# backup() not currently used. check the code carefully before using again
backup () {
    echo
    echo "****************************************************************"
    echo "- preparing to backup current LOOMA CODE to LoomaBAK"
    echo "-   *** usually it is OK to skip this step to save time"
    echo -n  "- - continue ('n' recommended) [y/n]?"; read input;
    if [[ $input = "y" ]]
    then
        if [ -d "$DESTINATION_URL/LoomaBAK" ]
        then
          echo "- deleting old LoomaBAK directory"
          sudo rm -r "$DESTINATION_URL/LoomaBAK"
          result $?
        fi
        mv    "$DESTINATION_URL/Looma"   "$DESTINATION_URL/LoomaBAk"
        result $?
    else
        echo " - - - SKIPPED: backing up Looma code "
    fi
}  #  end backup()


# ///////////////////////////////////////////////////////////
# /////////////     checknetworkspeed ()    /////////////////
# ///////////////////////////////////////////////////////////
checknetworkspeed () {
  # test internet presence and speed
    echo "************************************"
    echo "Testing network connection and speed"
    echo "************************************"
    echo
    t=$(date +%s)
    wget ftp://speedtest.tele2.net/10MB.zip -O /dev/null > /dev/null
    r=$?
    s=$(date +%s)
    if [[ $r -ne 0 ]]
    then
        echo "****************************************************************"
        echo "no internet connection found";exit $r;
    else
        echo "****************************************************************"
        echo -n "Internet speed is MB/s: ";expr 8 \* 10 / $(($s - $t))
        echo -n  "- - continue at this speed [y/n]?"; read input;
        if [[ $input != "y" ]]
        then
            exit 1
        fi
    fi
}  #  end checknetworkspeed()

# ///////////////////////////////////////////////////////////
# /////////////     checktimestamp ()    /////////////////////
# ///////////////////////////////////////////////////////////
# return 1 if timestamps are equal [ meaning no update is needed ]
checktimestamp () {    # call with
#                          $1 = local destination ($DESTINATION_URL is /var/www/html for Looma Boxes)
#                          $2 = source URL, either Looma Update server on rsync.net or USB stick
#                          $3 = source folder, either "Looma" or "content"
#                          $4 = source folder prefix, either "" or "preview/"

# echo "in checktimestamp(): source URL is $2, source dir is $3, source file is ${3}/archivetimestamp.txt"
# get timestamp of files currently on this Looma
  if [[ -f ${1}/${3}/archivetimestamp.txt ]]
   then
    // current=`cat "$1/$3/archivetimestamp.txt"`
     current=$(<"${1}/${3}/archivetimestamp.txt")

   else
     current="none"
   fi

# get timestamp of files on Looma Archive Server
  if [[ $source = "I" ]]
  then
      if [[ `which sshpass` != "" ]]
      then
        latest=`sshpass -p looma ssh $2 cat "../${4}${3}/archivetimestamp.txt"`
      else
        echo "enter password 'looma' if requested"
        latest=                 `ssh $2 cat "../${4}${3}/archivetimestamp.txt"`
      fi
  else   # source is USB stick
     latest=`cat "${2}/${3}/archivetimestamp.txt"`
  fi

# check if timestamps are equal
    echo " - - Current timestamp for $3 is    $current"
    echo " - - Latest timestamp for archive is $latest"
    if [[ $current = "$latest" ]]
    then
        return 1
    else
        return 0
    fi
}  #  end checktimestamp()

# ///////////////////////////////////////////////////////////
# /////////////     DOSYNC()    /////////////////
# ///////////////////////////////////////////////////////////
# function DOSYNC() to exec the rsync.
# global var $DRYRUNMODE is either "--dry-run" or ""
# call dosync() with:
#                          $1 = local destination (/var/www/html for Looma Boxes)
#                          $2 = source URL, either Looma Update server on rsync.net or USB stick
#                          $3 = source folder, either "Looma" or "content"
#                          $4 = source folder prefix, either "" or "preview/"

dosync () {

    # RSYNC_PASSWORD avoids manual entry of password for rsync (but, doesnt work?)
    # RSYNC_PASSWORD="looma"
    echo "**********************************";

    SYNC_DESTINATION="${1}/${3}"
    if [[ $source = "I" ]]
    then
        SYNC_SOURCE="${2}:../${4}/${3}"
    else
        SYNC_SOURCE="$2"
    fi

if [[ $3 = "content" ]]
    then
        SIZE_ONLY=" --size-only"
    else
        SIZE_ONLY=""
    fi

 if [[ $DRYRUNMODE = "--dry-run" ]]
    then
      echo "in dosync(): doing RSYNC from $2$4$3 to $1 with --dry-run [no changes will be made]"
    else
      echo "in dosync(): doing RSYNC from $2$4$3 to $1"
 fi
    echo
    #echo "  *** *** if prompted for \"password:\" enter \"looma\"  *** ***"

    if [[ `which sshpass` != "" ]]
      # NOTE, adding "O" option to avoid errors with modified date updates
    then
    sshpass -p 'looma' \
        rsync -rtvz  $DRYRUNMODE $SIZE_ONLY  \
        --stats  --times --itemize-changes \
        --perms --owner --group --chown=odroid:odroid --chmod=u+rwX,go+rX  \
        --include ".ssh/"  --exclude ".[!.]*" --exclude "vendor/" --exclude "composer*" \
        -e "ssh"   \
       $SYNC_SOURCE  $SYNC_DESTINATION
      # NOTE: RSYNC needs a slash after FROM dir and no slash after TO dir
    returncode=$?
     # NOTE, could try adding "O" option ["oh", not "zero"] to avoid errors with modified date updates
    else
      echo "enter password 'looma' if requested"
        rsync -rtvz  $DRYRUNMODE $SIZE_ONLY  \
        --stats  --times --itemize-changes \
        --perms --owner --group --chown=odroid:odroid --chmod=u+rwX,go+rX   \
        --include ".ssh/"  --exclude ".[!.]*" --exclude "vendor/" --exclude "composer*" \
        -e "ssh"   \
       $SYNC_SOURCE  $SYNC_DESTINATION
      # NOTE: RSYNC needs a slash after FROM dir and no slash after TO dir
      returncode=$?
    fi

  if [[ $DRYRUNMODE != "--dry-run"  && $returncode = 0 ]]
  then
     echo
     echo "**************************"
     echo "setting $SYNC_DESTINATION/archivetimestamp.txt to $latest [`date -r $latest`]"
     echo $latest > $SYNC_DESTINATION/archivetimestamp.txt
     echo
 fi

 if [[ $returncode != 0 ]]
 then
     echo "looma update 'rsync' operation from $SYNC_SOURCE failed with error $returncode. rerun 'loomaupdate' later"
     exit
 fi
}  #  end dosync()

# ///////////////////////////////////////////////////////////
# /////////////     start of main code      /////////////////
# ///////////////////////////////////////////////////////////

checksudo       # warn and quit if not running in 'sudo'

echo
echo "****************************************************************"
echo "START LOOMA UPDATE: updating Looma code, database and content"
echo "****************************************************************"
echo "this a DANGEROUS operation and can disable a Looma"
echo "Be sure you have read the instructions"
echo "****************************************************************"


if [[ "$1" != "dryrun" && "$2" != "dryrun" ]]
  then
    DRYRUNMODE=""
  else
    DRYRUNMODE="--dry-run"
fi

contenttime=0
codetime=0

#####################
##################### user input - choose update from USB stick or from Internet
#####################
echo; echo "****************************************************************"
echo "- Update using Internet connection or USB memory?"
echo -n  "- -enter  U for USB, I for internet [I/U]?"; read source

if [[ $source = "U" ]]
then

########################################
###########################  sourcing from USB - settings  #############

  SOURCE_URL="/media/odroid/LOOMA/loomaupdate/"   # for Linux (different for MAC)
  SOURCE_EXTENSION=""

      echo; echo "****************************************************************"
      echo "    you must insert a USB memory stick which is named LOOMA"
      echo "    be sure the USB filesystem format is FAT32 or exFAT    [*** not NTFS ***]"
      echo "    the USB stick must have the files to be uploaded stored in a top-level folder named 'loomaupdate' "
      echo "****************************************************************"

      cd $SOURCE_URL

      if [ "$?" -ne 0 ]
      then
          echo; echo "ERROR: couldn't find $SOURCE_URL directory on USB"
          exit 1
      fi

      echo
      echo -n  "- using this directory to get new files: ";pwd
      echo

########################################
###########################  sourcing from the Internet-  settings ###############

  elif [[ $source = "I" ]]
  then
      # URL for rsync.net Looma Archive Server
     SOURCE_URL="58191@usw-s008.rsync.net"

	if [[ "$1" = "preview" || "$2" == "preview" ]]
	  then
	      SOURCE_EXTENSION="preview/"
	  else
	      SOURCE_EXTENSION=""
	fi

    echo; echo "****************************************************************"
    echo "-   *** you can check network speed before proceeding"
    echo -n  "- - check and report network speed [y/n]?"; read input;
    if [[ $input = "y" ]]
    then
      checknetworkspeed
    fi
  else
      echo; echo "****************************************************************"
      echo 'ERROR: input must be "U" or "I"'
      echo "****************************************************************"
      exit 1
  fi

########################### set the target directory ###############E

echo "********************"

   DESTINATION_URL="/var/www/html"

   if [ ! -d $DESTINATION_URL/Looma ];
     then
       echo "Target directory does not contain a /Looma folder"
       exit
   fi

###############  do the transfers ###############
#################################################
    #       copy current Looma code to LoomaBAK
    #       NOTE: call to function backup() commented out for now to save time
    # backup

    checktimestamp $DESTINATION_URL  $SOURCE_URL "Looma" $SOURCE_EXTENSION

    if [[ $? = 1 ]]
      then
        echo "++++++++++++++++++++++++"
        echo "/$DESTINATION_URL/Looma is UP TO DATE [No files  will be transferred]"
        echo "++++++++++++++++++++++++"
      else

       #       install new Looma code
        echo
        echo "****************************************************************"
        echo "- preparing to update LOOMA CODE"
        echo -n  "- - continue ('y' recommended) [y/n]?"; read input;
        if [[ $input = "y" ]]
        then

        SECONDS=0
        echo
        echo "starting to update code files. please wait ..."
        echo

        #### calling DOSYNC() ##########

        dosync "$DESTINATION_URL" "$SOURCE_URL" "Looma"  "$SOURCE_EXTENSION"

        echo "$(($SECONDS / 60)) minutes and $(($SECONDS % 60)) seconds elapsed."
        codetime=$SECONDS

          if [[ -d "$DESTINATION_URL/Looma/mongo-dump/dump/looma" && "$DRYRUNMODE" != "--dry-run" ]]
                then
                    echo
                    echo "starting to update Looma's database. please wait ..."
                    echo

                      if which mongo
                      then
                         mongo --quiet --eval "db.dropDatabase();" looma
                      elif which mongosh
                      then
                         mongosh --quiet --eval "db.dropDatabase();" looma
                      fi

                    #mongosh --quiet --eval "db.dropDatabase();" looma

                    mongorestore --quiet --db looma "/$DESTINATION_URL/Looma/mongo-dump/dump/looma/"

                    if [[ -f "$DESTINATION_URL/Looma/mongo-dump/logins/defaultlogins.json" ]]
                    then
                       mongoimport --quiet --db loomausers --collection logins  --mode upsert --upsertFields name --file "$DESTINATION_URL/Looma/mongo-dump/logins/defaultlogins.json"
                       rm "$DESTINATION_URL/Looma/mongo-dump/logins/defaultlogins.json"
                    fi
                else echo "ERROR: no source dir ($DESTINATION_URL/Looma/mongo-dump/dump/looma) found for mongo restore"
                fi
        else
            echo " - - - SKIPPED: installing new Looma code"
        fi
   fi

#################################################
    #       copy new files into "content" directory
#################################################

        ########## NOTE: content always comes from ../content. there is no separate ../preview/content folder
    SOURCE_EXTENSION=""
    checktimestamp $DESTINATION_URL  $SOURCE_URL "content" $SOURCE_EXTENSION

    if [[ $? = 1 ]]
      then
        echo "++++++++++++++++++++++++"
        echo "$DESTINATION_URL/content is UP TO DATE [No files will be transferred]"
        echo "++++++++++++++++++++++++"
      else
        echo
        echo "****************************************************************"
        echo "- preparing to update files in CONTENT directory"
        echo -n  "- - continue ('y' recommended) [y/n]?"; read input;
        if [[ $input = "y" ]]
        then
           SECONDS=0

            #  for CONTENT calling dosync()
            echo
            echo "starting to update content files. this takes a long time. please wait ..."
            echo
            #### calling DOSYNC() ##########
            dosync "$DESTINATION_URL" "$SOURCE_URL" "content"  ""

            echo "$(($SECONDS / 60)) minutes and $(($SECONDS % 60)) seconds elapsed."
            contenttime=$SECONDS
        else
            echo " - - - SKIPPED: installing new Looma content"
        fi
  fi

  echo "*****************************************"
  echo "Total $(( ($contenttime + $codetime) / 60)) minutes and $(( ($contenttime + $codetime)  % 60)) seconds elapsed."

echo "*****************************************"
echo
echo "  deleting browser cache";
if [ -d "/home/odroid/snap/chromium/common/chromium/Default/Cache" ]; then
  rm -rf "/home/odroid/snap/chromium/common/chromium/Default/Cache"
fi
#rm -R /home/odroid/snap/chromium/common/chromium/Default/Cache
echo

echo "****************************************************************"
echo "****************************************************************"
 if [[ $DRYRUNMODE = "--dry-run" ]]
 then
    echo "DONE - LOOMA UPDATE DRY RUN:  no files were changed"
 else
    echo "DONE - LOOMA UPDATE: updating Looma code, database and content"
 fi
echo "****************************************************************"
echo "****************************************************************"
echo

